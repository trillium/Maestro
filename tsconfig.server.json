{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"strict": false,
		"noImplicitAny": false,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": false,
		"sourceMap": true,
		"baseUrl": ".",
		"types": ["node"]
	},
	"include": [
		"src/server/**/*.ts",
		"src/shared/**/*.ts",
		"src/main/web-server/**/*.ts",
		"src/main/themes.ts",
		"src/main/utils/logger.ts",
		"src/main/utils/networkUtils.ts",
		"src/main/utils/sentry.ts",
		"src/main/process-manager/**/*.ts",
		"src/main/parsers/**/*.ts",
		"src/main/agents/definitions.ts",
		"src/main/agents/capabilities.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"**/*.test.ts",
		"**/__tests__/**",
		"src/shared/hooks/**/*",
		"src/shared/stores/**/*",
		"src/shared/utils/bionifyReadingMode.tsx",
		"src/shared/utils/markdownConfig.ts"
	]
}
